{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Claude: developer",
      "type": "shell",
      "command": "claude",
      "args": ["--append-system-prompt-file", ".claude/commands/developer.md"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "group": "agents",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Claude: reviewer",
      "type": "shell",
      "command": "claude",
      "args": ["--append-system-prompt-file", ".claude/commands/reviewer.md"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "group": "agents",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Claude: release-manager",
      "type": "shell",
      "command": "claude",
      "args": ["--append-system-prompt-file", ".claude/commands/release-manager.md"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "group": "agents",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Start agent workspace",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Claude: developer",
        "Claude: reviewer",
        "Claude: release-manager"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
